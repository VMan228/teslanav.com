# Waze account email (used for OTP re-auth if IMAP is configured)
WAZE_EMAIL=your@email.com

# Optional — IMAP inbox for automated OTP retrieval on session expiry.
# Create a Gmail App Password at https://myaccount.google.com/apppasswords
# Leave blank to use manual cookie bootstrap only.
WAZE_OTP_IMAP_HOST=imap.gmail.com
WAZE_OTP_IMAP_PORT=993
WAZE_OTP_IMAP_USER=your@gmail.com
WAZE_OTP_IMAP_PASS=your-app-password
