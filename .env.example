# ─────────────────────────────────────────────────────────────────────────────
# TeslaNav — Docker environment template
# Copy to .env and fill in values:  cp .env.example .env
# .env is read automatically by docker compose. NEVER commit .env.
# ─────────────────────────────────────────────────────────────────────────────

# ── Build-time: baked into client JS bundles at image build (NEXT_PUBLIC_) ───

# Mapbox — map rendering + directions  https://account.mapbox.com
NEXT_PUBLIC_MAPBOX_TOKEN=pk.eyJ1IjoiWU9VUl9VU0VSTkFNRSIsImEiOiJZT1VSX0tFWSJ9.PLACEHOLDER

# PostHog — product analytics  https://posthog.com
NEXT_PUBLIC_POSTHOG_KEY=phc_PLACEHOLDER
NEXT_PUBLIC_POSTHOG_HOST=https://us.posthog.com

# Shutdown mode — "false" for normal operation, "true" for maintenance page
NEXT_PUBLIC_PROJECT_SHUTDOWN=false

# ── Runtime-only: server-side secrets, never sent to the browser ──────────────

# Upstash Redis — caching and rate limiting  https://console.upstash.com
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-rest-token

# Vercel Blob — GPX recording storage  https://vercel.com/docs/storage/vercel-blob
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_PLACEHOLDER

# LocationIQ — geocoding and place search  https://locationiq.com
LOCATIONIQ_API_KEY=pk.PLACEHOLDER

# Inbound — feedback emails and admin alerts (optional)  https://inbound.new
INBOUND_API_KEY=PLACEHOLDER

# Admin dashboard — protects /api/admin/* routes
# Generate:  openssl rand -hex 32
ADMIN_API_KEY=REPLACE_WITH_STRONG_SECRET

# OpenWeb Ninja — Waze fallback API (used only when sidecar is unavailable)
# Leave empty if always using the sidecar.  https://app.openwebninja.com
WAZE_API_KEY=

# ── Waze sidecar ──────────────────────────────────────────────────────────────
# RECOMMENDED: Run the sidecar as a systemd host service with Xvfb (headed
# Chromium) — see services/waze-sidecar/deploy/setup.sh — then set:
WAZE_SIDECAR_URL=http://host.docker.internal:8001
#
# Alternatives:
#   Docker sidecar (local dev):  http://waze-sidecar:8000
#                                (docker compose --profile sidecar up)
#   Disabled (OWN API fallback): leave WAZE_SIDECAR_URL empty

# Waze account email (required for sidecar startup and IMAP re-auth)
WAZE_EMAIL=your@email.com

# Optional — IMAP inbox for automated OTP retrieval on session expiry.
# Create a Gmail App Password: https://myaccount.google.com/apppasswords
# Leave blank to use manual cookie bootstrap only.
WAZE_OTP_IMAP_HOST=imap.gmail.com
WAZE_OTP_IMAP_PORT=993
WAZE_OTP_IMAP_USER=your@gmail.com
WAZE_OTP_IMAP_PASS=your-app-password

# Sidecar log level (DEBUG | INFO | WARNING | ERROR)
LOG_LEVEL=INFO
